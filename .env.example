# Yap Text Inference — Environment Variables
#
# Copy to .env and fill in the values you need.
# Every variable has a sensible default — only set what you want to override.
# Common required runtime variables are left uncommented with empty values.

# =============================================================================
# Deployment & Models
# =============================================================================

# API key clients must supply to authenticate WebSocket connections.
TEXT_API_KEY=

# Deployment mode: "both" (chat + tool), "chat", or "tool".
# DEPLOY_MODE=both

# HuggingFace model ID for the chat engine (required when mode includes chat).
CHAT_MODEL=

# HuggingFace model ID for the tool model (required when mode includes tool).
TOOL_MODEL=

# Inference backend for chat/both deployments: "trt" (TensorRT-LLM) or "vllm".
# Tool-only mode is engine-agnostic and does not use this variable.
# INFERENCE_ENGINE=trt

# Optional override for chat quantization detection: "awq", "gptq", "fp8", etc.
# CHAT_QUANTIZATION=

# =============================================================================
# GPU & Memory
# =============================================================================

# Fraction of GPU memory allocated to the chat engine.
# Default: 0.70 in "both" mode, 0.90 in single-engine mode.
# CHAT_GPU_FRAC=0.70

# Fraction of GPU memory allocated to the tool model.
# Default: 0.20 in "both" mode, 0.90 in single-engine mode.
# TOOL_GPU_FRAC=0.20

# Optional cap used when scaling vLLM batching from available GPU memory.
# Default: derived from CHAT_GPU_FRAC for the active deployment mode.
# BATCH_SCALE_GPU_FRAC_CAP=

# KV-cache data type: "auto", "fp8", or explicit dtype string.
# KV_DTYPE=auto

# Override GPU SM architecture (e.g., "sm89" for Ada). Auto-detected if empty.
# GPU_SM_ARCH=

# =============================================================================
# TensorRT-LLM
# =============================================================================

# Path to pre-built TRT engine directory (containing rank0.engine, etc.).
# TRT_ENGINE_DIR=

# Path to TRT checkpoint directory (used during engine build).
# TRT_CHECKPOINT_DIR=

# Path to the TRT-LLM repo (for build scripts).
# TRT_REPO_DIR=

# Maximum batch size for TRT engine build (required before building a TRT engine).
# At runtime the value is read from compiled engine metadata.
# TRT_MAX_BATCH_SIZE=

# Runtime batch size. Auto-derived if unset.
# TRT_BATCH_SIZE=

# Maximum input sequence length. Default: derived CHAT_MAX_LEN.
# TRT_MAX_INPUT_LEN=

# Maximum output sequence length. Default: CHAT_MAX_OUT.
# TRT_MAX_OUTPUT_LEN=

# TRT engine dtype: "float16", "bfloat16", etc.
# TRT_DTYPE=float16

# Fraction of GPU memory for KV cache (default: CHAT_GPU_FRAC).
# TRT_KV_FREE_GPU_FRAC=

# Calibration sequence length. Default: CHAT_MAX_LEN + CHAT_MAX_OUT.
# TRT_CALIB_SEQLEN=

# TRT AWQ block size used in metadata/build scripts.
# TRT_AWQ_BLOCK_SIZE=128

# TRT calibration sample count used in metadata/build scripts.
# TRT_CALIB_SIZE=64

# TRT calibration batch size used in metadata/build scripts.
# TRT_CALIB_BATCH_SIZE=16

# Override TRT KV-cache dtype in generated metadata.
# TRT_KV_CACHE_DTYPE=

# TRT KV-cache type for generated metadata.
# TRT_KV_CACHE_TYPE=paged

# Enable KV-cache reuse flag in generated metadata (1 = enabled, 0 = disabled).
# TRT_KV_CACHE_REUSE=1

# Override detected TensorRT-LLM version for engine labeling/metadata.
# TRT_VERSION=

# Override detected CUDA version for engine labeling/metadata.
# CUDA_VERSION=

# =============================================================================
# vLLM
# =============================================================================

# Enable vLLM V1 engine (1 = on, 0 = off).
# VLLM_USE_V1=1

# Attention backend: "FLASHINFER", "XFORMERS", or auto-detected.
# VLLM_ATTENTION_BACKEND=

# Disable CUDA graphs for debugging (1 = eager mode).
# ENFORCE_EAGER=0

# Hard fallback max batched tokens when no model profile provides one.
# DEFAULT_MAX_BATCHED_TOKENS=256

# Explicit max batched tokens override for the chat engine.
# MAX_NUM_BATCHED_TOKENS_CHAT=

# =============================================================================
# Chat Behavior
# =============================================================================

# Prefix prepended when the tool model detects a screen-check request.
# CHECK_SCREEN_PREFIX=MUST CHECK SCREEN:

# Prefix prepended when the screen has already been checked.
# SCREEN_CHECKED_PREFIX=ON THE SCREEN NOW:

# Enable <thinking> tags in chat template (for reasoning models).
# CHAT_TEMPLATE_ENABLE_THINKING=false

# Interval between periodic vLLM cache resets (seconds).
# CACHE_RESET_INTERVAL_SECONDS=600

# Minimum session duration before a disconnect triggers a cache reset (seconds).
# CACHE_RESET_MIN_SESSION_SECONDS=300

# =============================================================================
# Sampling Defaults
# =============================================================================

# Default sampling temperature.
# CHAT_TEMPERATURE=0.8

# Nucleus sampling top-p.
# CHAT_TOP_P=0.95

# Top-k sampling.
# CHAT_TOP_K=30

# Min-p sampling threshold.
# CHAT_MIN_P=0.0

# Repetition penalty (1.0 = no penalty).
# CHAT_REPETITION_PENALTY=1.0

# Presence penalty.
# CHAT_PRESENCE_PENALTY=0.0

# Frequency penalty.
# CHAT_FREQUENCY_PENALTY=0.0

# Path to a JSON file with per-token logit biases.
# CHAT_LOGIT_BIAS_FILE=

# =============================================================================
# Context & Token Limits
# =============================================================================

# Maximum tokens allowed in the chat system prompt.
# CHAT_PROMPT_MAX_TOKENS=1500

# Maximum tokens for conversation history (triggers trimming threshold).
# CHAT_HISTORY_MAX_TOKENS=3000

# Maximum tokens for a single user utterance.
# USER_UTT_MAX_TOKENS=500

# Additional reserved tokens added to CHAT_MAX_LEN budget.
# CONTEXT_BUFFER=25

# Percentage of CHAT_HISTORY_MAX_TOKENS to retain after trimming (valid: 30-90).
# HISTORY_RETENTION_PCT=66

# Maximum generation output length (tokens).
# CHAT_MAX_OUT=150

# =============================================================================
# Tool Model
# =============================================================================

# Confidence threshold for tool classification decisions.
# TOOL_DECISION_THRESHOLD=0.66

# Enable torch.compile for the tool model (may improve throughput).
# TOOL_COMPILE=false

# Optional maximum history tokens fed to the tool model.
# If unset, the adapter uses the model's effective max input length.
# TOOL_HISTORY_TOKENS=

# =============================================================================
# WebSocket
# =============================================================================

# Idle timeout before the server closes an inactive connection (seconds).
# WS_IDLE_TIMEOUT_S=150

# Interval for the idle-watchdog heartbeat check (seconds).
# WS_WATCHDOG_TICK_S=10

# Max time to wait for a connection slot before rejecting the handshake (seconds).
# WS_HANDSHAKE_ACQUIRE_TIMEOUT_S=0.5

# WebSocket protocol version exposed in server payloads.
# WS_PROTOCOL_VERSION=1

# Maximum raw incoming WebSocket message size in bytes.
# WS_MAX_MESSAGE_BYTES=65536

# Shared rate-limit window duration for messages, cancels, and auth (seconds).
# WS_RATE_LIMIT_WINDOW=60

# Maximum auth failures per auth rate-limit window.
# WS_MAX_AUTH_FAILURES_PER_WINDOW=10

# Optional comma-separated allowed Origin values. Empty = no origin allowlist.
# WS_ALLOWED_ORIGINS=

# Maximum concurrent WebSocket connections (required, must be >= 1).
MAX_CONCURRENT_CONNECTIONS=

# Micro-buffer flush interval for streaming chunks (ms, 0 = no buffering).
# STREAM_FLUSH_MS=0

# Maximum messages per rate-limit window.
# WS_MAX_MESSAGES_PER_WINDOW=20

# Maximum cancel requests per rate-limit window.
# WS_MAX_CANCELS_PER_WINDOW=20

# =============================================================================
# Timeouts
# =============================================================================

# Maximum time for a single chat generation before timeout (seconds).
# CHAT_TIMEOUT_S=60

# Maximum time to wait for a tool classification result (seconds).
# TOOL_TIMEOUT_S=3

# Timeout for HuggingFace license-info lookups (seconds).
# HF_LICENSE_FETCH_TIMEOUT=5


# =============================================================================
# Logging
# =============================================================================

# Application log level: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# APP_LOG_LEVEL=INFO

# Optional Python logging format string.
# APP_LOG_FORMAT=%(levelname)s %(asctime)s name=%(name)s session_id=%(session_id)s request_id=%(request_id)s client_id=%(client_id)s msg=%(message)s

# =============================================================================
# HuggingFace
# =============================================================================

# HuggingFace API token for downloading private/gated models.
# HF_TOKEN=

# Optional HuggingFace cache directory override.
# HF_HOME=

# =============================================================================
# HTTP
# =============================================================================

# Comma-separated CIDR allowlist for health endpoints.
# HEALTH_ALLOWED_CIDRS=127.0.0.1/32,::1/128

# =============================================================================
# Quantization & Calibration
# =============================================================================

# Default dataset alias for calibration helpers.
# CALIB_DATASET_DEFAULT=open_platypus

# Total chat tokens used by calibration helpers. Default: CHAT_MAX_LEN + CHAT_MAX_OUT.
# CALIB_CHAT_TOTAL_LEN=

# AWQ calibration dataset override.
# AWQ_CALIB_DATASET=open_platypus

# AWQ calibration sample count.
# AWQ_NSAMPLES=64

# AWQ calibration sequence length.
# AWQ_SEQLEN=2048

# Optional patch script applied during quantization workflows.
# TRANSFORMERS_PATCH_SCRIPT=

# Show HuggingFace library logs during quantization workflows (1 = on, 0 = off).
# SHOW_HF_LOGS=0

# =============================================================================
# Telemetry — Sentry (error reporting)
# =============================================================================
# Set SENTRY_DSN to enable. Leave empty or omit to run without Sentry.

# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=
# SENTRY_SAMPLE_RATE=1.0

# =============================================================================
# Telemetry — Axiom (metrics + traces via OpenTelemetry)
# =============================================================================
# Set AXIOM_API_TOKEN to enable. Leave empty or omit to run without Axiom.

# AXIOM_API_TOKEN=xaat-xxxxxxxx
# AXIOM_DATASET=text-inference-api
# AXIOM_ENVIRONMENT=production

# =============================================================================
# Telemetry — Cloud platform & OTel tuning
# =============================================================================

# Cloud platform tag for fleet identification.
# CLOUD_PLATFORM=

# OpenTelemetry service name attached to every span and metric.
# OTEL_SERVICE_NAME=yap-text-inference-api

# Span batch flush interval (ms).
# OTEL_TRACES_EXPORT_INTERVAL_MS=5000

# Metric export interval (ms).
# OTEL_METRICS_EXPORT_INTERVAL_MS=15000

# Maximum spans per export batch.
# OTEL_TRACES_BATCH_SIZE=512
