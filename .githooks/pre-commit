#!/usr/bin/env bash
# Pre-commit orchestrator for full lint, quality, and hook self-checks.

set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
HOOKS_DIR="${ROOT_DIR}/.githooks/hooks"

# shellcheck disable=SC1091  # lint:justify -- reason: sourced relative hook runtime helper -- ticket: N/A
source "${ROOT_DIR}/.githooks/lib/runtime.sh"

if [[ ${SKIP_HOOKS:-0} == "1" ]]; then
  exit 0
fi

FAILED=0
# shellcheck disable=SC2034  # lint:justify -- reason: variable name is passed indirectly to run_hook_no_stdin -- ticket: N/A
SKIP_PYTHON_STAGE="${SKIP_PYTHON:-${SKIP_CODE:-0}}"
HOOK_PIDS=()
HOOK_NAMES=()
HOOK_TMPDIR="$(mktemp -d)"

# run_hook_bg - Execute a hook stage in the background and buffer its output.
run_hook_bg() {
  local name="$1"
  local skip_var="$2"
  local timeout_seconds="$3"
  local script="$4"
  shift 4

  local should_skip="${!skip_var-0}"
  if [[ ${should_skip} == "1" ]] || [[ ! -x ${script} ]]; then
    return 0
  fi

  local idx=${#HOOK_PIDS[@]}
  HOOK_NAMES+=("${name}")
  (
    run_with_timeout "${timeout_seconds}" "${script}" "$@" >"${HOOK_TMPDIR}/${idx}.out" 2>&1
  ) &
  HOOK_PIDS+=($!)
}

trap 'rm -rf "${HOOK_TMPDIR}"' EXIT

run_hook_no_stdin "[pre-commit] env guard" "SKIP_ENV_CHECK" "${TIMEOUT_FAST_HOOKS}" "${HOOKS_DIR}/global/security.sh" --mode=commit
if ! run_hook_no_stdin "[pre-commit] docs" "SKIP_DOCS" "${TIMEOUT_FULL_HOOKS}" "${HOOKS_DIR}/global/lint.sh" --mode=commit; then
  FAILED=1
fi

run_hook_bg "[pre-commit] python" "SKIP_PYTHON_STAGE" "${TIMEOUT_FULL_HOOKS}" "${HOOKS_DIR}/project/python.sh" --mode=commit
run_hook_bg "[pre-commit] shell" "SKIP_SHELL" "${TIMEOUT_FULL_HOOKS}" "${HOOKS_DIR}/project/shell.sh" --mode=commit
run_hook_bg "[pre-commit] docker" "SKIP_DOCKER" "${TIMEOUT_FULL_HOOKS}" "${HOOKS_DIR}/project/docker.sh" --mode=commit
run_hook_bg "[pre-commit] quality" "SKIP_QUALITY" "${TIMEOUT_FULL_HOOKS}" "${HOOKS_DIR}/project/quality.sh" --mode=commit
run_hook_bg "[pre-commit] hooks lint" "SKIP_HOOKS_SELF" "${TIMEOUT_FULL_HOOKS}" "${HOOKS_DIR}/self/lint.sh"
run_hook_bg "[pre-commit] hooks security" "SKIP_HOOKS_SELF" "${TIMEOUT_FULL_HOOKS}" "${HOOKS_DIR}/self/security.sh"
run_hook_bg "[pre-commit] hooks format" "SKIP_HOOKS_SELF" "${TIMEOUT_FULL_HOOKS}" "${HOOKS_DIR}/self/format.sh"
run_hook_bg "[pre-commit] hooks quality" "SKIP_HOOKS_SELF" "${TIMEOUT_FULL_HOOKS}" "${HOOKS_DIR}/self/quality.sh"

for idx in "${!HOOK_PIDS[@]}"; do
  if ! wait "${HOOK_PIDS[$idx]}"; then
    OUTPUT="$(cat "${HOOK_TMPDIR}/${idx}.out" 2>/dev/null)"
    if [[ ${OUTPUT} != "skip" ]]; then
      echo -e "${RED}${HOOK_NAMES[$idx]}${NC}"
      [[ -n ${OUTPUT} ]] && echo "${OUTPUT}"
      FAILED=1
    fi
  fi
done

if [[ ${FAILED} == "1" ]]; then
  echo -e "${RED}Commit blocked. Bypass: git commit --no-verify${NC}"
  exit 1
fi

exit 0
