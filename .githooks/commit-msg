#!/usr/bin/env bash
# Conventional commit validator for git commit messages.

set -euo pipefail

if [[ ${SKIP_HOOKS:-0} == "1" ]] || [[ ${SKIP_GITLINT:-0} == "1" ]] || [[ ${SKIP_COMMITLINT:-0} == "1" ]]; then
  exit 0
fi

ROOT_DIR="$(git rev-parse --show-toplevel)"
# shellcheck disable=SC1091  # lint:justify -- reason: commit-msg must source the repo hook bootstrap to resolve repo-managed gitlint -- ticket: N/A
source "${ROOT_DIR}/.githooks/lib/bootstrap.sh"

if ! command -v gitlint >/dev/null 2>&1; then
  echo "error: gitlint is required for commit-message linting" >&2
  exit 1
fi

gitlint --config .gitlint --msg-filename "$1"
