#!/usr/bin/env bash
# Pre-push orchestrator for security scans and opt-in coverage.

set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
HOOKS_DIR="${ROOT_DIR}/.githooks/hooks"

# shellcheck disable=SC1091  # lint:justify -- reason: sourced relative hook runtime helper -- ticket: N/A
source "${ROOT_DIR}/.githooks/lib/runtime.sh"

if [[ ${SKIP_HOOKS:-0} == "1" ]]; then
  exit 0
fi

FAILED=0
if ! run_hook_no_stdin "[pre-push] security" "SKIP_SECURITY_SCANS" "${TIMEOUT_SECURITY_HOOKS}" "${HOOKS_DIR}/project/security.sh" --mode=push; then
  FAILED=1
fi
if ! run_hook_no_stdin "[pre-push] coverage" "_NOSKIP" "${TIMEOUT_FULL_HOOKS}" "${HOOKS_DIR}/project/coverage.sh" --mode=push; then
  FAILED=1
fi

if [[ ${FAILED} == "1" ]]; then
  echo -e "${RED}Push blocked. Bypass: git push --no-verify${NC}"
  exit 1
fi

exit 0
