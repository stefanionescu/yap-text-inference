#!/usr/bin/env bash

# lint:justify -- reason: configuration file sourced by security wrappers -- ticket: N/A
# shellcheck disable=SC2034

BEARER_IMAGE="bearer/bearer:${BEARER_VERSION}"
BEARER_CONFIG_FILE="bearer.yml"
BEARER_TOOL_NAME="bearer"
BEARER_RELEASE_BASE_URL="https://github.com/Bearer/bearer/releases/download"
BEARER_ARCHIVE_PREFIX="bearer"
BEARER_CHECKSUMS_FILE="checksums.txt"
BEARER_OS_DARWIN="darwin"
BEARER_OS_LINUX="linux"
BEARER_ARCH_AMD64="amd64"
BEARER_ARCH_ARM64="arm64"
BEARER_SCAN_ROOT="."
BEARER_FLAGS=(
  --format json
  --severity "critical,high,medium"
  --quiet
  --exit-code 1
)
