#!/usr/bin/env bash

# lint:justify -- reason: configuration file sourced by security wrappers -- ticket: N/A
# shellcheck disable=SC2034

TRIVY_IMAGE="aquasec/trivy:${TRIVY_VERSION}"
TRIVY_IGNORE_FILE=".trivyignore"
TRIVY_DOCKER_PLATFORM="linux/amd64"
TRIVY_CONFIG_TARGETS=("docker")
TRIVY_FS_TARGET="."
TRIVY_IMAGE_TARGET_SPECS=(
    "tool|docker/tool|requirements-tool.txt|0|yap-text-inference-trivy-tool:local|DEPLOY_MODE=tool,TOOL_MODEL=linting/trivy-tool,TRIVY_SCAN=1"
    "trt|docker/trt|requirements-trt.txt|1|yap-text-inference-trivy-trt:local|DEPLOY_MODE=both,CHAT_MODEL=linting/trivy-chat,TOOL_MODEL=linting/trivy-tool,TRT_ENGINE_REPO=linting/trivy-engine,TRT_ENGINE_LABEL=lint-scan,TRIVY_SCAN=1"
    "vllm|docker/vllm|requirements-vllm.txt|1|yap-text-inference-trivy-vllm:local|DEPLOY_MODE=both,CHAT_MODEL=linting/trivy-chat,TOOL_MODEL=linting/trivy-tool,TRIVY_SCAN=1"
)
