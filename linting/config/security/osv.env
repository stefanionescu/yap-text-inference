#!/usr/bin/env bash

# lint:justify -- reason: configuration file sourced by security wrappers -- ticket: N/A
# shellcheck disable=SC2034

OSV_SCANNER_IMAGE="ghcr.io/google/osv-scanner:v${OSV_SCANNER_VERSION}"
OSV_SCAN_ROOT="."
OSV_SCAN_ARGS=("scan" "source" "--recursive" "--no-resolve" "--verbosity" "warn")
OSV_SCANNER_TOOL_NAME="osv-scanner"
OSV_SCANNER_RELEASE_BASE_URL="https://github.com/google/osv-scanner/releases/download"
OSV_SCANNER_ASSET_PREFIX="osv-scanner"
OSV_SCANNER_CHECKSUMS_ASSET="osv-scanner_SHA256SUMS"
OSV_SCANNER_OS_DARWIN="darwin"
OSV_SCANNER_OS_LINUX="linux"
OSV_SCANNER_ARCH_AMD64="amd64"
OSV_SCANNER_ARCH_ARM64="arm64"
