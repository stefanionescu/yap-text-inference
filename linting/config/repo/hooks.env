#!/usr/bin/env bash

# lint:justify -- reason: configuration file sourced by git hook helpers -- ticket: N/A
# shellcheck disable=SC2034

RED='\033[0;31m'
YELLOW='\033[0;33m'
NC='\033[0m'

TIMEOUT_FAST_HOOKS=90
TIMEOUT_FULL_HOOKS=900
TIMEOUT_SECURITY_HOOKS=1800

HOOK_ENTRYPOINTS=("pre-commit" "pre-push" "commit-msg")
HOOK_FILE_PATTERN='^\.githooks/.*\.sh$|^\.githooks/(pre-commit|pre-push|commit-msg)$'
DOCS_FILE_PATTERN='(^README\.md$|\.md$|\.mdx$|\.txt$|\.py$|\.sh$|Dockerfile$|\.toml$|\.json$|\.ya?ml$|^\.githooks/(pre-commit|pre-push|commit-msg)$)'
MARKDOWN_FILE_PATTERN='(^README\.md$|\.md$|\.mdx$)'
PYTHON_FILE_PATTERN='\.py$'
SHELL_FILE_PATTERN='(^\.githooks/(pre-commit|pre-push|commit-msg)$|\.sh$)'
DOCKERFILE_PATTERN='^docker/.+/Dockerfile$'
DOCKER_POLICY_PATTERN='(^docker/|(^|/)\.dockerignore$)'
PROD_ENV_PATTERN='(^|/)\.env\.(prod|production)$'

HOOK_SELF_JSCPD_CONFIG='.githooks/.jscpd/bash.json'
HOOK_SELF_SEMGREP_CONFIG='r/bash'
