{
    "threshold": 4,
    "reporters": ["console"],
    "format": ["python"],
    "ignore": [
        "**/.git/**",
        "**/.venv/**",
        "**/node_modules/**",
        "**/.jscpd-report/**",
        "**/__pycache__/**",
        "**/.pytest_cache/**",
        "**/.ruff_cache/**",
        "**/.mypy_cache/**",
        "**/tests/support/messages/**",
        "**/tests/support/prompts/**"
    ],
    "path": [
        "../src",
        "../tests",
        "../docker",
        "../linting"
    ],
    "minLines": 8,
    "minTokens": 40,
    "mode": "strict",
    "output": "../.jscpd-report/python"
}
